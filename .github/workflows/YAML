version: '1.0'
services: "web3"

  termux:
    image: termux/android
    restart: always
    command: ["/data/data/elparadisogonzalo.com/files/home/start_termux.sh"]
    environment:
      - TERMUX_HOME=/data/data/elparadisogonzalo.com/files/home
      - PATH=/data/data/elparadisogonzalo.com/files/usr/bin:$PATH
    volumes: "51200gb"
      - /data/data/com.termux/files/home:/home/termux
      - /sdcard/:
    network_mode: "host"
