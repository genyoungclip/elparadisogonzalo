{
  "name": "elparadisogonzalo LLM Development",
  "image": "ghcr.io/genyoungclip/elparadisogonzalo:latest",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "username": "azehagowa"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21"
    },
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.24"
    },
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "10.0"
    },
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {}
  },

  "forwardPorts": [
    3000,
    5173,
    8000,
    8080,
    8545,
    11434
  ],

  "portsAttributes": {
    "3000": {
      "label": "Node.js App",
      "onAutoForward": "openBrowser"
    },
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "openBrowser"
    },
    "8000": {
      "label": "LLM API"
    },
    "8080": {
      "label": "Web Service"
    },
    "8545": {
      "label": "Ethereum JSON-RPC"
    },
    "11434": {
      "label": "Local LLM Server"
    }
  },

  "containerEnv": {
    "NODE_ENV": "development",
    "PYTHONUNBUFFERED": "1",
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1"
  },

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.formatOnSave": true,
        "files.autoSave": "afterDelay"
      },
      "extensions": [
        "ms-vscode.vscode-typescript-next",
        "ms-python.python",
        "node.js",
        "elparadisogonzalo",
        "ms-dotnettools.csharp",
        "golang.go",
        "rust-lang.rust-analyzer",
        "GitHub.vscode-github-actions",
        "openai-api",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ]
    }
  },

  "postCreateCommand": "npm install || true && pip install -r requirements.txt || true",

  "remoteUser": "Termux"
}
